[project]
name = "tossinvest"
version = "0.1.0"
description = "CostAvg and Value Rebal with Tossinvest API"
authors = [
    {name = "kettledrum",email = "[EMAIL_ADDRESS]"}
]
readme = "README.md"
requires-python = ">=3.12"
dependencies = [
    "streamlit (>=1.55.0)",
    "pandas (>=2.2.0,<3.0.0)",
    "plotly (>=6.6.0,<7.0.0)",
    "requests (>=2.33.0,<3.0.0)",
    "python-dotenv (>=1.2.2,<2.0.0)",
    "apscheduler (>=3.11.2,<4.0.0)",
    "pytz (>=2026.1.post1,<2027.0)",
    "openpyxl (>=3.1.5,<4.0.0)"
]


[build-system]
requires = ["poetry-core>=2.0.0,<3.0.0"]
build-backend = "poetry.core.masonry.api"
